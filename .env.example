# Firebase config — copy to .env.local and fill in from Firebase Console
# (Project Settings → Your apps → Web app)
# If any of these are missing, the app stays local-storage-only and the
# "Sign in" option is hidden.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Create ONE account in Firebase Console → Authentication → Users.
# That single account is the "fixed credential" allowed to sync.
